# --- App ---------------------------------------------------------------
# MUST be the exact public origin (no trailing slash). On Vercel set this to
# your deployed URL, e.g. https://shipflow-ai.vercel.app — it is used to build
# every OAuth callback URL and to sign auth cookies.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Database (Drizzle / Postgres) --------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/shipflowai

# --- Better Auth ---------------------------------------------------------
# REQUIRED in production. Missing/empty => /api/auth/sign-in/social returns 500.
BETTER_AUTH_SECRET=             # generate: openssl rand -hex 32
# Google OAuth (https://console.cloud.google.com -> Credentials -> OAuth client).
# Authorized redirect URI: <NEXT_PUBLIC_APP_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GitHub OAuth App used ONLY for login (https://github.com/settings/developers).
# Authorization callback URL: <NEXT_PUBLIC_APP_URL>/api/auth/callback/github
# Missing/empty => GitHub authorize URL gets client_id=undefined -> 404.
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# --- GitHub App (repo access + webhooks) ---------------------------------
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=         # paste full PEM; \n line breaks are unescaped automatically
GITHUB_APP_WEBHOOK_SECRET=
GITHUB_APP_SLUG=                # used to build the public install page URL if needed

# --- AI / Vector ----------------------------------------------------------
OPENROUTER_API_KEY=
PINECONE_API_KEY=
PINECONE_INDEX=                 # pre-create a 1536-dim index; see README (Pass 6) for exact command

# --- Inngest ---------------------------------------------------------------
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
INNGEST_DEV=1                   # set when using local Inngest dev server

# --- Razorpay ---------------------------------------------------------------
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PRO_PLAN_ID=            # create in Razorpay Dashboard > Subscriptions > Plans
RAZORPAY_ENTERPRISE_PLAN_ID=

# --- Local tunneling ------------------------------------------------------
# ngrok http 3000   →  use the printed https URL as your GitHub App webhook
#                      URL and as NEXT_PUBLIC_APP_URL for OAuth callback testing.


