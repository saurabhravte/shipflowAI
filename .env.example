# --- App ---------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Database (Drizzle / Postgres) --------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/shipflowai

# --- Better Auth ---------------------------------------------------------
BETTER_AUTH_SECRET=             # generate: openssl rand -hex 32
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_OAUTH_CLIENT_ID=         # separate OAuth App used ONLY for login
GITHUB_OAUTH_CLIENT_SECRET=

# --- GitHub App (repo access + webhooks) ---------------------------------
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=         # paste full PEM; \n line breaks are unescaped automatically
GITHUB_APP_WEBHOOK_SECRET=
GITHUB_APP_SLUG=                # used to build the public install page URL if needed

# --- AI / Vector ----------------------------------------------------------
OPENROUTER_API_KEY=
PINECONE_API_KEY=
PINECONE_INDEX=                 # pre-create a 1536-dim index; see README (Pass 6) for exact command

# --- Inngest ---------------------------------------------------------------
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
INNGEST_DEV=1                   # set when using local Inngest dev server

# --- Razorpay ---------------------------------------------------------------
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PRO_PLAN_ID=            # create in Razorpay Dashboard > Subscriptions > Plans
RAZORPAY_ENTERPRISE_PLAN_ID=

# --- Local tunneling ------------------------------------------------------
# ngrok http 3000   →  use the printed https URL as your GitHub App webhook
#                      URL and as NEXT_PUBLIC_APP_URL for OAuth callback testing.


